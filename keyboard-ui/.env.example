# Local backend (default: http://localhost:5000)
VITE_API_URL=http://localhost:5000

# Cloud API fallback (Coolify VPS) — used when local backend is offline
# Set this to your Coolify API URL for Vercel deployment
VITE_CLOUD_API_URL=https://your-coolify-api.example.com

# Deploy mode: "cloud" hides local-only panels (OBS, YT Chat, Briefing)
# VITE_DEPLOY_MODE=cloud
