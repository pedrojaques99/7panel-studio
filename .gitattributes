# Auto-detect text and normalize line endings
* text=auto

# Windows scripts — force CRLF
*.bat text eol=crlf
*.vbs text eol=crlf
*.ps1 text eol=crlf
*.ahk text eol=crlf

# Unix scripts — force LF
*.sh text eol=lf

# Source code — normalize to LF
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.webm binary
*.mp3 binary
*.wav binary
*.m4a binary
*.mp4 binary
*.zip binary
